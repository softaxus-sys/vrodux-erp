generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  phone       String?
  country     String?
  subject     String?
  message     String
  source      String   @default("contact")
  status      LeadStatus @default(NEW)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model DemoBooking {
  id               String   @id @default(cuid())
  name             String
  email            String
  company          String
  phone            String?
  country          String?
  employees        String?
  industry         String?
  preferredDate    String?
  preferredTime    String?
  notes            String?
  status           BookingStatus @default(PENDING)
  calendlyEventUri String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  status      SubscriberStatus @default(ACTIVE)
  source      String   @default("website")
  ipAddress   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  category    String
  tags        String[]
  author      String   @default("Vrodux Team")
  authorImage String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  views       Int      @default(0)
  readTime    Int      @default(5)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  country   String?
  subject   String
  message   String
  status    MessageStatus @default(UNREAD)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}
