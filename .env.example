# Application
NEXT_PUBLIC_SITE_URL=https://vrodux.com
NEXT_PUBLIC_APP_URL=https://erp.vrodux.com

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/vrodux_erp_db?schema=public"

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@vrodux.com
CONTACT_EMAIL=info@vrodux.com
DEMO_EMAIL=demo@vrodux.com

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=xxxxxxxxx

# Calendly
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/vrodux/demo

# Admin
ADMIN_SECRET_KEY=your-super-secret-admin-key-here

# Rate Limiting
UPSTASH_REDIS_REST_URL=https://xxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx
